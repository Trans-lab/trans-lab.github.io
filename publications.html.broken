<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Publications from Quantitative Translation Research Lab - Hong Kong Polytechnic University">

    <title>Publications | Quantitative Translation Research Lab</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Sans+Pro:wght@400;600&display=swap" rel="stylesheet">

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Design System CSS -->
    <link href="css/design-system.css" rel="stylesheet">
    <!-- Enhanced Mobile Optimizations -->
    <link href="css/mobile-typography.css" rel="stylesheet">
    
    <!-- Language Switcher -->
    <script src="js/language-switcher.js"></script>
    <!-- Mobile Navigation -->
    <script src="js/mobile-nav.js"></script>

    <style>
        /* Compact Publication Layout */
        .search-filter-bar {
            background: var(--bg-primary);
            padding: var(--space-6);
            border-radius: var(--radius-xl);
            box-shadow: var(--shadow-md);
            margin-bottom: var(--space-6);
        }

        .search-box {
            position: relative;
            margin-bottom: var(--space-3);
        }

        .search-box input {
            width: 100%;
            padding: var(--space-3) var(--space-5);
            padding-left: var(--space-10);
            border: 2px solid var(--color-gray-200);
            border-radius: var(--radius-lg);
            font-size: var(--text-base);
            transition: all var(--transition-fast);
        }

        .search-box input:focus {
            outline: none;
            border-color: var(--color-primary-500);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        }

        .search-box i {
            position: absolute;
            left: var(--space-3);
            top: 50%;
            transform: translateY(-50%);
            color: var(--color-gray-400);
        }

        .filter-buttons {
            display: flex;
            flex-wrap: wrap;
            gap: var(--space-2);
        }

        .filter-btn {
            padding: var(--space-2) var(--space-3);
            background: var(--color-gray-100);
            border: 2px solid transparent;
            border-radius: var(--radius-full);
            color: var(--color-gray-700);
            font-weight: var(--font-medium);
            font-size: var(--text-sm);
            cursor: pointer;
            transition: all var(--transition-fast);
        }

        .filter-btn:hover {
            background: var(--color-primary-50);
            color: var(--color-primary-700);
        }

        .filter-btn.active {
            background: var(--color-primary-600);
            color: white;
            border-color: var(--color-primary-600);
        }

        /* Compact Year Section */
        .publication-year {
            margin-bottom: var(--space-4);
        }

        .year-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: var(--space-3) var(--space-4);
            background: linear-gradient(135deg, var(--color-primary-700), var(--color-primary-600));
            color: white;
            border-radius: var(--radius-lg);
            margin-bottom: var(--space-2);
            cursor: pointer;
            transition: all var(--transition-fast);
        }

        .year-header:hover {
            transform: translateX(4px);
        }

        .year-title {
            font-size: var(--text-xl);
            font-weight: var(--font-bold);
        }

        .year-count {
            background: rgba(255, 255, 255, 0.2);
            padding: var(--space-1) var(--space-2);
            border-radius: var(--radius-full);
            font-size: var(--text-xs);
        }

        .year-toggle {
            transition: transform var(--transition-fast);
        }

        .year-header.collapsed .year-toggle {
            transform: rotate(-90deg);
        }

        .publication-list {
            display: grid;
            gap: var(--space-2);
            overflow: hidden;
            max-height: 5000px;
            transition: max-height var(--transition-slow);
        }

        .publication-list.collapsed {
            max-height: 0;
        }

        /* Ultra Compact Publication Item */
        .publication-item {
            background: var(--bg-primary);
            padding: var(--space-3) var(--space-4);
            border-radius: var(--radius-md);
            box-shadow: var(--shadow-sm);
            border-left: 3px solid var(--color-primary-500);
            transition: all var(--transition-fast);
            display: flex;
            align-items: flex-start;
            gap: var(--space-3);
        }

        .publication-item:hover {
            transform: translateX(4px);
            box-shadow: var(--shadow-md);
        }

        .pub-number {
            font-weight: var(--font-bold);
            color: var(--color-primary-600);
            min-width: 30px;
            font-size: var(--text-sm);
        }

        .pub-content {
            flex: 1;
        }

        .pub-meta {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: var(--space-2);
            margin-bottom: var(--space-1);
        }

        .pub-type {
            padding: 2px var(--space-2);
            border-radius: var(--radius-full);
            font-size: 10px;
            font-weight: var(--font-semibold);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .pub-type.journal {
            background: var(--color-primary-100);
            color: var(--color-primary-700);
        }

        .pub-type.conference {
            background: var(--color-accent-100);
            color: var(--color-accent-700);
        }

        .pub-type.book {
            background: #dcfce7;
            color: #166534;
        }

        .pub-type.chapter {
            background: #fef3c7;
            color: #92400e;
        }

        .pub-title {
            font-size: var(--text-base);
            color: var(--color-gray-900);
            margin-bottom: var(--space-1);
            line-height: 1.4;
        }

        .pub-authors {
            color: var(--color-gray-600);
            margin-bottom: var(--space-1);
            font-size: var(--text-sm);
            line-height: 1.3;
        }

        .pub-journal {
            color: var(--color-gray-500);
            font-style: italic;
            font-size: var(--text-sm);
            line-height: 1.3;
        }

        .highlight-author {
            font-weight: var(--font-semibold);
            color: var(--color-primary-700);
        }

        .pub-actions {
            display: flex;
            flex-wrap: wrap;
            gap: var(--space-2);
            margin-top: var(--space-2);
        }

        .pub-link {
            display: inline-flex;
            align-items: center;
            gap: var(--space-1);
            padding: var(--space-1) var(--space-2);
            background: var(--color-gray-100);
            border-radius: var(--radius-sm);
            color: var(--color-gray-700);
            font-size: var(--text-xs);
            text-decoration: none;
            transition: all var(--transition-fast);
        }

        .pub-link:hover {
            background: var(--color-primary-50);
            color: var(--color-primary-700);
            text-decoration: none;
        }

        .pub-link i {
            font-size: var(--text-sm);
        }

        /* Stats Bar */
        .pub-stats {
            display: flex;
            gap: var(--space-6);
            padding: var(--space-4);
            background: var(--bg-primary);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-sm);
            margin-bottom: var(--space-6);
            flex-wrap: wrap;
        }

        .pub-stat {
            display: flex;
            align-items: center;
            gap: var(--space-2);
        }

        .pub-stat-number {
            font-size: var(--text-2xl);
            font-weight: var(--font-bold);
            color: var(--color-primary-700);
        }

        .pub-stat-label {
            font-size: var(--text-sm);
            color: var(--color-gray-600);
        }

        @media (max-width: 768px) {
            .filter-buttons {
                justify-content: center;
            }

            .pub-stats {
                flex-direction: column;
                gap: var(--space-3);
            }

            .publication-item {
                flex-direction: column;
            }

            .pub-number {
                margin-bottom: var(--space-1);
            }
        }
    </style>
    <!-- Language Switcher -->
    <script src="js/language-switcher.js"></script>
</head>
<body>
    <!-- Header & Navigation -->
    <header class="header" id="header">
        <div class="header-inner">
            <a href="index.html" class="logo">
                <i class="fas fa-language"></i>
                <span>Trans-Lab</span>
            </a>

            <nav>
                <ul class="nav-menu">
                    <li><a href="index.html" class="nav-link" data-i18n="nav.home">Home</a></li>
                    <li><a href="people.html" class="nav-link" data-i18n="nav.people">People</a></li>
                    <li><a href="grants.html" class="nav-link" data-i18n="nav.grants">Grants</a></li>
                    <li><a href="publications.html" class="nav-link active" data-i18n="nav.publications">Publications</a></li>
                    <li><a href="corpus-resources.html" class="nav-link" data-i18n="nav.resources">Resources</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <!-- Hero Section (Smaller) -->
    <section class="hero" style="padding: var(--space-16) var(--space-6);">
        <div class="hero-content">
            <h1 class="hero-title" style="font-size: var(--text-5xl);" data-i18n="publications.title">Publications</h1>
            <p class="hero-subtitle" style="font-size: var(--text-lg);" data-i18n="publications.subtitle">
                Research contributions to quantitative translation studies
            </p>
        </div>
    </section>

    <!-- Main Content -->
    <main class="container-wrapper">

        <!-- Stats -->
        <div class="pub-stats animate-fade-in-up">
            <div class="pub-stat">
                <div class="pub-stat-number">66+</div>
                <div class="pub-stat-label" data-i18n="publications.stats.total">Total Publications</div>
            </div>
            <div class="pub-stat">
                <div class="pub-stat-number">37</div>
                <div class="pub-stat-label" data-i18n="publications.stats.journal">Journal Articles</div>
            </div>
            <div class="pub-stat">
                <div class="pub-stat-number">20</div>
                <div class="pub-stat-label" data-i18n="publications.stats.chapters">Book Chapters</div>
            </div>
            <div class="pub-stat">
                <div class="pub-stat-number">7</div>
                <div class="pub-stat-label" data-i18n="publications.stats.books">Books & Edited Volumes</div>
            </div>
        </div>

        <!-- Search and Filter -->
        <div class="search-filter-bar animate-fade-in-up">
            <div class="search-box">
                <i class="fas fa-search"></i>
                <input type="text" id="searchInput" placeholder="Search by title, author, or keyword..." data-i18n-placeholder="publications.search">
            </div>
            <div class="filter-buttons">
                <button class="filter-btn active" data-filter="all">All Types</button>
                <button class="filter-btn" data-filter="journal">Journal</button>
                <button class="filter-btn" data-filter="book">Books</button>
                <button class="filter-btn" data-filter="chapter">Chapters</button>
            </div>
        </div>

        <!-- Publications Content -->
        <section class="content" id="publicationsContainer">

            

